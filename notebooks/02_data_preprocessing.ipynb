    "import re\n",
    "import unicodedata\n",
    "\n",
    "def clean_product_name(name):\n",
    "    if name is None:\n",
    "        return None\n",
    "\n",
    "    name = str(name)\n",
    "    name = unicodedata.normalize(\"NFKC\", name)\n",
    "\n",
    "    # bỏ dấu ngoặc kép đầu/cuối\n",
    "    name = re.sub(r'^[\"\\']+|[\"\\']+$', \"\", name)\n",
    "\n",
    "    # thay khoảng trắng đặc biệt\n",
    "    name = name.replace(\"\\xa0\", \" \")\n",
    "    name = re.sub(r\"[\\r\\n\\t]+\", \" \", name)\n",
    "\n",
    "    # bỏ ký tự rác\n",
    "    name = re.sub(r\"[|_]+\", \" \", name)\n",
    "    name = re.sub(r\"[★☆✔✅•◆◉●■□]+\", \" \", name)\n",
    "\n",
    "    # chuẩn hóa dấu gạch\n",
    "    name = re.sub(r\"[–—]+\", \"-\", name)\n",
    "    name = re.sub(r\"\\s*-\\s*\", \" - \", name)\n",
    "\n",
    "    # bỏ cụm quảng cáo\n",
    "    promo_patterns = [\n",
    "        r\"\\bchính hãng\\b\",\n",
    "        r\"\\bfreeship\\b\",\n",
    "        r\"\\bgiao nhanh\\b\",\n",
    "        r\"\\bgiá tốt\\b\",\n",
    "        r\"\\bquà tặng\\b\",\n",
    "        r\"\\bkhuyến mãi\\b\",\n",
    "        r\"\\bsiêu sale\\b\",\n",
    "        r\"\\bgiá sốc\\b\",\n",
    "        r\"\\bưu đãi\\b\",\n",
    "        r\"\\bhot deal\\b\",\n",
    "        r\"\\bdeal sốc\\b\",\n",
    "        r\"\\bflash sale\\b\",\n",
    "        r\"\\bgiảm\\s*\\d+\\s*%?\\b\",\n",
    "    ]\n",
    "    for pattern in promo_patterns:\n",
    "        name = re.sub(pattern, \"\", name, flags=re.IGNORECASE)\n",
    "\n",
    "    # bỏ ký tự đặc biệt dư\n",
    "    name = re.sub(r\"[^\\w\\s\\-\\+/%().,]\", \" \", name, flags=re.UNICODE)\n",
    "\n",
    "    # gom khoảng trắng\n",
    "    name = re.sub(r\"\\s+\", \" \", name).strip()\n",
    "\n",
    "    # bỏ dấu dư đầu/cuối\n",
    "    name = name.strip(\" -–—,.;:/\")\n",
    "\n",
    "    return name if name else None\n",
    "\n",
    "\n",
    "def to_display_name(name):\n",
    "    if name is None:\n",
    "        return None\n",
    "\n",
    "    name = clean_product_name(name)\n",
    "    if name is None:\n",
    "        return None\n",
    "\n",
    "    # Chuẩn hóa về dạng hiển thị đẹp:\n",
    "    # chỉ viết hoa chữ cái đầu, con lại viết thường\n",
    "    name = name.lower()\n",
    "    name = name.title()\n",
    "\n",
    "    replacements = {\n",
    "        \"Jlpt\": \"JLPT\",\n",
    "        \"N1\": \"N1\",\n",
    "        \"N2\": \"N2\",\n",
    "        \"N3\": \"N3\",\n",
    "        \"N4\": \"N4\",\n",
    "        \"N5\": \"N5\",\n",
    "        \"Try\": \"TRY\",\n",
    "    }\n",
    "    for old, new in replacements.items():\n",
    "        name = re.sub(rf\"\\b{old}\\b\", new, name)\n",
    "\n",
    "    return name\n",
    "\n",
    "\n",
    "def to_standard_name(name):\n",
    "    if name is None:\n",
    "        return None\n",
    "\n",
    "    name = clean_product_name(name)\n",
    "    if name is None:\n",
    "        return None\n",
    "\n",
    "    # Chuẩn hóa 1 dạng để làm dashboard (viết thường hết)\n",
    "    name = name.lower()\n",
    "    name = re.sub(r\"\\s+\", \" \", name).strip()\n",
    "\n",
    "    return name if name else None\n",
    "\n",
    "\n",
    "df_product_clean = df_product.with_columns([\n",
    "    pl.col(\"product_name\")\n",
    "      .map_elements(clean_product_name, return_dtype=pl.String)\n",
    "      .alias(\"product_name_clean\"),\n",
    "\n",
    "    pl.col(\"product_name\")\n",
    "      .map_elements(to_display_name, return_dtype=pl.String)\n",
    "      .alias(\"product_name_display\"),\n",
    "\n",
    "    pl.col(\"product_name\")\n",
    "      .map_elements(to_standard_name, return_dtype=pl.String)\n",
    "      .alias(\"product_name_std\")\n",
    "])\n",
    "\n",
    "df_product_clean.select([\n",
    "    \"product_id\",\n",
    "    \"product_name\",\n",
    "    \"product_name_display\",\n",
    "    \"product_name_std\"\n",
    "]).head(100)"
   ]
  }
