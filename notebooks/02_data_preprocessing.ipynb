    "# Phân ra nhiều cấp từ category_path\n",
    "import re\n",
    "\n",
    "def normalize_text(text):\n",
    "    if text is None:\n",
    "        return None\n",
    "    text = str(text).replace(\"\\xa0\", \" \")\n",
    "    text = re.sub(r\"\\s+\", \" \", text).strip()\n",
    "    return text\n",
    "\n",
    "def clean_category_path(path):\n",
    "    path = normalize_text(path)\n",
    "    if not path:\n",
    "        return None\n",
    "\n",
    "    parts = path.split(\">\")\n",
    "    parts = [normalize_text(p) for p in parts]\n",
    "    parts = [p for p in parts if p]\n",
    "\n",
    "    return \" > \".join(parts)\n",
    "\n",
    "df_category_clean = df_category.with_columns(\n",
    "    pl.col(\"category_path\")\n",
    "    .map_elements(clean_category_path, return_dtype=pl.String)\n",
    "    .alias(\"category_path_clean\")\n",
    ").with_columns([\n",
    "    pl.col(\"category_path_clean\").str.split(\" > \").alias(\"category_levels\"),\n",
    "    pl.col(\"category_path_clean\").str.split(\" > \").list.len().alias(\"category_depth\"),\n",
    "    pl.col(\"category_path_clean\").str.split(\" > \").list.get(0, null_on_oob=True).alias(\"category_level_1\"),\n",
    "    pl.col(\"category_path_clean\").str.split(\" > \").list.get(1, null_on_oob=True).alias(\"category_level_2\"),\n",
    "    pl.col(\"category_path_clean\").str.split(\" > \").list.get(2, null_on_oob=True).alias(\"category_level_3\"),\n",
    "    pl.col(\"category_path_clean\").str.split(\" > \").list.get(-1, null_on_oob=True).alias(\"leaf_category\"),\n",
    "])\n",
    "\n",
    "df_category_clean.select([\n",
    "    \"category_id\",\n",
    "    \"category_name\",\n",
    "    \"category_path\",\n",
    "    \"category_path_clean\",\n",
    "    \"category_depth\",\n",
    "    \"category_level_1\",\n",
    "    \"category_level_2\",\n",
    "    \"category_level_3\",\n",
    "    \"leaf_category\"\n",
    "]).head(20)"
   ]
